{
  "name": "workflow-mcp",
  "version": "0.0.0",
  "private": true,
  "description": "Claude-compatible dynamic workflow loader and provider-neutral execution runtime.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./state": {
      "types": "./dist/state.d.ts",
      "default": "./dist/state.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "default": "./dist/worker.js"
    }
  },
  "bin": {
    "workflow-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && npm run check:browser-state && vitest run",
    "check:browser-state": "tsc -p tsconfig.browser-state.json",
    "test:integration": "npm run build && vitest run test/codexProvider.integration.test.ts",
    "benchmark:codex": "npm run build && node dist/benchmarkCodex.js",
    "check": "npm test",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20.14.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openai/codex-sdk": "0.144.4",
    "acorn": "8.15.0",
    "ajv": "8.20.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "license": "MIT"
}

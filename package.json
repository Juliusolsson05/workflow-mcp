{
  "name": "workflow-mcp",
  "version": "0.0.0",
  "private": true,
  "description": "Claude-compatible dynamic workflow loader and MCP runtime.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "workflow-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run build && npm test"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "acorn": "8.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "license": "MIT"
}
